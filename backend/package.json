{
  "name": "flowspace-backend",
  "version": "1.0.0",
  "description": "FlowSpace Backend API - Real-time collaboration platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:enterprise": "jest --testPathPattern=enterprise",
    "test:backup": "jest --testPathPattern=backup",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "backup:create": "tsx -e \"import { BackupService } from './src/services/backup.service'; new BackupService().createFullBackup().then(console.log).catch(console.error)\"",
    "backup:list": "tsx -e \"import { BackupService } from './src/services/backup.service'; new BackupService().listBackups().then(console.log).catch(console.error)\"",
    "enterprise:health": "tsx -e \"import { enterpriseService } from './src/services/enterprise.service'; enterpriseService.getSystemHealth().then(console.log).catch(console.error)\"",
    "enterprise:report": "tsx -e \"import { enterpriseService } from './src/services/enterprise.service'; enterpriseService.generateSystemReport().then(console.log).catch(console.error)\"",
    "enterprise:maintenance": "tsx -e \"import { enterpriseService } from './src/services/enterprise.service'; enterpriseService.performMaintenance().then(() => console.log('Maintenance completed')).catch(console.error)\"",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "docs:generate": "swagger-jsdoc -d swaggerDef.js src/routes/*.ts -o swagger.json",
    "docs:serve": "swagger-ui-serve swagger.json"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0-rc.4",
    "redis": "^4.6.10",
    "socket.io": "^4.7.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.9.4",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "prisma": "^5.7.0",
    "supertest": "^7.1.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "keywords": [
    "collaboration",
    "real-time",
    "chat",
    "workspace",
    "socket.io",
    "express",
    "prisma",
    "typescript"
  ],
  "author": "FlowSpace Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}